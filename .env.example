PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=ey...
PUBLIC_SUPABASE_SCHEMA=public

# Optional local-only key for scripts that write test data.
# Never expose this in PUBLIC_* variables and never commit .env.local.
SUPABASE_SERVICE_ROLE_KEY=ey...

# Basic Auth for the admin area (/admin) and write API (/api).
# If unset, /admin and /api are DISABLED (fail closed). Never commit real values.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
