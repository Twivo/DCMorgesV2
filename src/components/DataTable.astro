---
interface Props {
  headers: string[];
  rows?: string[][];
  emptyMessage?: string;
}

const { headers, rows = [], emptyMessage = "Aucune donnée publiée" } = Astro.props;
---

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        {headers.map((header) => <th>{header}</th>)}
      </tr>
    </thead>
    <tbody>
      {rows.length > 0 ? (
        rows.map((row) => (
          <tr>
            {row.map((cell) => <td>{cell}</td>)}
          </tr>
        ))
      ) : (
        <tr>
          <td colspan={headers.length}>{emptyMessage}</td>
        </tr>
      )}
    </tbody>
  </table>
</div>
