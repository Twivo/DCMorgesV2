---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { clubPalmaresLines } from "../data/clubPalmares";

const palmaresLines = [...clubPalmaresLines].sort(
  (a, b) =>
    (b.order ?? Number.NEGATIVE_INFINITY) - (a.order ?? Number.NEGATIVE_INFINITY) ||
    b.season.localeCompare(a.season, "fr") ||
    a.competition.localeCompare(b.competition, "fr")
);

const palmaresGroups = palmaresLines.reduce<Array<{ season: string; lines: typeof palmaresLines }>>((groups, line) => {
  const current = groups.at(-1);
  if (current?.season === line.season) {
    current.lines.push(line);
  } else {
    groups.push({ season: line.season, lines: [line] });
  }
  return groups;
}, []);
---

<BaseLayout title="Palmarès du club" description="Palmarès historique du Darts Club Morges.">
  <PageHero
    eyebrow="Club"
    title="Palmarès du club"
    description="Les principaux résultats du Darts Club Morges, saison par saison."
  />

  <section class="section">
    <div class="container palmares-page">
      <SectionHeader
        eyebrow="Historique"
        title="Résultats par saison"
        description="Championnat, coupes et résultats marquants du club."
      />

      <div class="palmares-years">
        {palmaresGroups.map((group) => {
          const headingId = `palmares-${group.season.replace(/\W+/g, "-")}`;
          return (
            <section class="palmares-year" aria-labelledby={headingId}>
              <h3 id={headingId}>{group.season}</h3>
              <div class="palmares-table-wrap">
                <table class="palmares-table">
                  <thead>
                    <tr>
                      <th>Compétition</th>
                      <th>Résultat</th>
                    </tr>
                  </thead>
                  <tbody>
                    {group.lines.map((line) => (
                      <tr>
                        <td>{line.competition}</td>
                        <td>{line.result}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          );
        })}
      </div>
    </div>
  </section>

  <style>
    .palmares-page {
      display: grid;
      gap: 20px;
    }

    .palmares-years {
      display: grid;
      gap: 18px;
    }

    .palmares-year {
      display: grid;
      gap: 10px;
    }

    .palmares-year h3 {
      margin: 0;
      color: var(--color-red-dark);
      font-size: 1.15rem;
      font-weight: 850;
      line-height: 1.2;
    }

    .palmares-table-wrap {
      width: 100%;
      overflow-x: auto;
      border: 1px solid var(--color-line);
      border-radius: 8px;
      background: var(--color-surface);
      box-shadow: var(--shadow-sm);
    }

    .palmares-table {
      min-width: 680px;
    }

    .palmares-table th:first-child {
      width: 42%;
    }

    .palmares-table td {
      color: var(--color-ink);
    }
  </style>
</BaseLayout>
