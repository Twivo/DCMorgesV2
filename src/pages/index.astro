---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import NewsCard from "../components/NewsCard.astro";
import EventCard from "../components/EventCard.astro";
import DocumentCard from "../components/DocumentCard.astro";
import { documents } from "../data/documents";
import { clubPalmaresLines } from "../data/clubPalmares";
import { homeDocuments } from "../data/homeDocuments";
import { upcomingEvents } from "../data/events";
import { newsItems } from "../data/news";
import { formatPageActions, formatPageSection, formatPageText, getPageSection, getSitePage } from "../data/pages";
import { seasons } from "../data/seasons";
import { quickLinks, siteInfo } from "../data/site";

const page = getSitePage("home");
const currentSeason = seasons.find((season) => season.isCurrent);
const currentSeasonLabel = currentSeason?.label ?? "2025-26";
const pageVars = { update: siteInfo.update, siteName: siteInfo.name, currentSeason: currentSeasonLabel };
const clubInfoSection = formatPageSection(getPageSection(page, "club-info"), pageVars);
const quickLinksSection = formatPageSection(getPageSection(page, "quick-links"), pageVars);
const latestNewsSection = formatPageSection(getPageSection(page, "latest-news"), pageVars);
const nextEventsSection = formatPageSection(getPageSection(page, "next-events"), pageVars);
const documentsSection = formatPageSection(getPageSection(page, "documents"), pageVars);
const latestNews = newsItems.slice(0, 3);
const nextEvents = upcomingEvents.slice(0, 3);
// The 6 featured document cards are curated in the admin (Documents en avant).
// Fall back to the newest documents of the season if none are configured yet.
const highlightedDocuments = (homeDocuments.length > 0
  ? homeDocuments
  : documents.filter((document) => document.season === currentSeasonLabel)
).slice(0, 6);

const clubFacts = [
  { label: "Lieu", value: siteInfo.location },
  { label: "Compétitions", value: "Swiss Darts Association, Ligue Morgienne de Fléchettes, coupes suisses et vaudoises" },
  { label: "Archives", value: "Résultats SDA, LMF, GDL, LVSD, Morges Open, Open Vaudois et Master Tour" }
];

const clubMilestones = [...clubPalmaresLines]
  .filter((line) => !line.result.toLowerCase().includes("pas de"))
  .sort(
    (a, b) =>
      (b.order ?? Number.NEGATIVE_INFINITY) - (a.order ?? Number.NEGATIVE_INFINITY) ||
      b.season.localeCompare(a.season, "fr")
  )
  .slice(0, 4)
  .map((line) => `${line.season} : ${line.result} (${line.competition}).`);
---

<BaseLayout title={page.seoTitle} description={page.seoDescription || siteInfo.description}>
  <PageHero
    variant="home"
    image={siteInfo.heroImage}
    eyebrow={formatPageText(page.heroEyebrow, pageVars)}
    title={formatPageText(page.heroTitle, pageVars)}
    description={formatPageText(page.heroDescription, pageVars)}
    actions={formatPageActions(page.actions, pageVars)}
  />

  <section class="section home-history-section">
    <div class="container home-history">
      <div class="home-history__main">
        <SectionHeader
          eyebrow={clubInfoSection.eyebrow}
          title={clubInfoSection.title}
          description={clubInfoSection.description}
        />
        <div class="button-row">
          <a class="button button--outline" href="/club/">Palmarès</a>
          <a class="button button--outline" href="/archives/">Archives</a>
        </div>
      </div>

      <div class="home-history__details" aria-label="Repères du club">
        <dl class="home-history__facts">
          {clubFacts.map((fact) => (
            <div>
              <dt>{fact.label}</dt>
              <dd>{fact.value}</dd>
            </div>
          ))}
        </dl>

        <div class="home-history__milestones">
          <h3>Repères récents</h3>
          <ul>
            {clubMilestones.map((milestone) => <li>{milestone}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--muted">
    <div class="container">
      <SectionHeader
        eyebrow={quickLinksSection.eyebrow}
        title={quickLinksSection.title}
        description={quickLinksSection.description}
      />
      <div class="card-grid card-grid--four">
        {quickLinks.map((link) => (
          <a class="content-card quick-card" href={link.href}>
            <span>{link.label}</span>
            <p>{link.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow={latestNewsSection.eyebrow}
        title={latestNewsSection.title}
        description={latestNewsSection.description}
      />
      <div class="card-grid card-grid--three">
        {latestNews.map((news) => <NewsCard news={news} />)}
      </div>
    </div>
  </section>

  <section class="section section--muted">
    <div class="container">
      <SectionHeader
        eyebrow={nextEventsSection.eyebrow}
        title={nextEventsSection.title}
        description={nextEventsSection.description}
      />
      {nextEvents.length > 0 ? (
        <div class="card-grid card-grid--three">
          {nextEvents.map((event) => <EventCard event={event} />)}
        </div>
      ) : (
        <p class="muted">Aucun événement à venir pour le moment. Consulte l'agenda pour l'historique.</p>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow={documentsSection.eyebrow}
        title={documentsSection.title}
        description={documentsSection.description}
      />
      <div class="card-grid card-grid--three">
        {highlightedDocuments.map((document) => <DocumentCard document={document} />)}
      </div>
    </div>
  </section>

  <style is:global>
    .home-history-section {
      padding-block: 48px;
    }

    .home-history {
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(420px, 1.1fr);
      gap: 34px;
      align-items: start;
    }

    .home-history .section-header {
      margin-bottom: 18px;
    }

    .home-history .section-header p {
      margin-bottom: 0;
      line-height: 1.55;
    }

    .home-history__details {
      display: grid;
      gap: 18px;
      min-width: 0;
      padding-top: 8px;
    }

    .home-history__facts {
      display: grid;
      gap: 10px;
      margin: 0;
    }

    .home-history__facts > div {
      display: grid;
      grid-template-columns: 120px minmax(0, 1fr);
      gap: 18px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--color-line);
    }

    .home-history__facts dt,
    .home-history__milestones h3 {
      color: var(--color-red-dark);
      font-size: 0.78rem;
      font-weight: 850;
      text-transform: uppercase;
    }

    .home-history__facts dd {
      margin: 0;
      color: var(--color-ink);
      line-height: 1.45;
    }

    .home-history__milestones {
      display: grid;
      gap: 8px;
    }

    .home-history__milestones h3 {
      margin: 0;
      font-size: 0.82rem;
    }

    .home-history__milestones ul {
      display: grid;
      gap: 6px;
      margin: 0;
      padding-left: 18px;
      color: var(--color-ink);
      line-height: 1.45;
    }

    @media (max-width: 900px) {
      .home-history {
        grid-template-columns: 1fr;
        gap: 22px;
      }

      .home-history__details {
        padding-top: 0;
      }
    }

    @media (max-width: 560px) {
      .home-history-section {
        padding-block: 38px;
      }

      .home-history__facts > div {
        grid-template-columns: 1fr;
        gap: 3px;
      }
    }
  </style>
</BaseLayout>
