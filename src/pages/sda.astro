---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import DocumentCard from "../components/DocumentCard.astro";
import TeamCard from "../components/TeamCard.astro";
import { getDocumentsByCompetition } from "../data/documents";
import { formatPageActions, formatPageSection, formatPageText, getPageSection, getSitePage } from "../data/pages";
import { seasons } from "../data/seasons";
import { teams } from "../data/teams";

const page = getSitePage("sda");
const currentSeason = seasons.find((season) => season.isCurrent);
const currentSeasonLabel = currentSeason?.label ?? "2025-26";
const pageVars = { currentSeason: currentSeasonLabel };
const currentSeasonSection = formatPageSection(getPageSection(page, "current-season"), pageVars);
const teamsSection = formatPageSection(getPageSection(page, "teams"), pageVars);
const documentsSection = formatPageSection(getPageSection(page, "documents"), pageVars);
const sdaDocuments = getDocumentsByCompetition("SDA");
const currentSdaDocuments = sdaDocuments.filter((document) => document.season === currentSeasonLabel);
const sdaTeams = teams.filter((team) => team.competition === "SDA");
---

<BaseLayout title={page.seoTitle} description={page.seoDescription}>
  <PageHero
    eyebrow={formatPageText(page.heroEyebrow, pageVars)}
    title={formatPageText(page.heroTitle, pageVars)}
    description={formatPageText(page.heroDescription, pageVars)}
    actions={formatPageActions(page.actions, pageVars)}
  />

  <section class="section">
    <div class="container split-layout">
      <div>
        <SectionHeader
          eyebrow={currentSeason?.label}
          title={currentSeasonSection.title}
          description={currentSeasonSection.description}
        />
      </div>
      <div class="info-strip">
        <div>
          <span class="label">Saison</span>
          <strong>{currentSeasonLabel}</strong>
        </div>
        <div>
          <span class="label">Documents SDA</span>
          <strong>{currentSdaDocuments.length} fichiers</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--muted">
    <div class="container">
      <SectionHeader eyebrow={teamsSection.eyebrow} title={teamsSection.title} description={teamsSection.description} />
      <div class="card-grid card-grid--two">
        {sdaTeams.map((team) => <TeamCard team={team} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow={documentsSection.eyebrow}
        title={documentsSection.title}
        description={documentsSection.description}
      />
      <div class="card-grid card-grid--three">
        {currentSdaDocuments.map((document) => <DocumentCard document={document} />)}
      </div>
    </div>
  </section>
</BaseLayout>
