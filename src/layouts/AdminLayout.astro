---
import { collections } from "../lib/collections";
import { siteInfo } from "../data/site";

interface Props {
  title: string;
  active?: string;
}

interface AdminLink {
  label: string;
  href: string;
  active: string;
  hint?: string;
}

interface AdminGroup {
  title: string;
  links: AdminLink[];
}

const { title, active } = Astro.props;

const collectionByName = new Map(collections.map((collection) => [collection.name, collection]));
const collectionLink = (name: string, label?: string, hint?: string): AdminLink | undefined => {
  const collection = collectionByName.get(name);
  if (!collection) return undefined;
  return {
    label: label ?? collection.label,
    href: `/admin/${collection.name}`,
    active: collection.name,
    hint
  };
};

const compact = <T,>(items: Array<T | undefined>): T[] => items.filter(Boolean) as T[];

const primaryLinks: AdminLink[] = [
  { label: "Accueil admin", href: "/admin", active: "dashboard" },
  { label: "Modifier le site", href: "/admin/content", active: "content", hint: "Entrée recommandée" },
  { label: "Médiathèque", href: "/admin/media", active: "media" },
  { label: "Réglages", href: "/admin/site", active: "site" }
];

const navGroups: AdminGroup[] = [
  {
    title: "Pages et textes",
    links: compact([
      collectionLink("pages", "Textes des pages", "Bandeaux et sections"),
      collectionLink("news", "News"),
      collectionLink("events", "Agenda"),
      collectionLink("videos", "Vidéos")
    ])
  },
  {
    title: "Cartes documents",
    links: compact([
      collectionLink("home-documents", "Accueil"),
      collectionLink("sda-documents", "SDA"),
      collectionLink("lmf-documents", "LMF"),
      collectionLink("documents", "Bibliothèque")
    ])
  },
  {
    title: "Club",
    links: compact([
      collectionLink("club-palmares", "Palmarès"),
      collectionLink("members", "Membres"),
      collectionLink("teams", "Équipes"),
      collectionLink("seasons", "Saisons")
    ])
  },
  {
    title: "Archives",
    links: compact([
      collectionLink("archives", "Carrés archives"),
      collectionLink("archive-groups", "Groupes"),
      collectionLink("legacy-pages", "Pages sources")
    ])
  },
  {
    title: "Contact",
    links: compact([collectionLink("contact-blocks", "Blocs contact")])
  }
].filter((group) => group.links.length > 0);

const isActive = (value: string) => active === value;
const isGroupActive = (group: AdminGroup) => group.links.some((link) => isActive(link.active));
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <title>{title} · Admin {siteInfo.shortName}</title>
  </head>
  <body>
    <div class="admin">
      <aside class="admin-side">
        <a class="admin-brand" href="/admin">
          <img src={siteInfo.logo} alt="" width="34" height="34" />
          <span>Admin<small>{siteInfo.shortName}</small></span>
        </a>

        <nav class="admin-nav" aria-label="Navigation administration">
          <div class="admin-nav__main">
            {primaryLinks.map((link) => (
              <a href={link.href} class:list={[{ "is-active": isActive(link.active), "is-prominent": link.active === "content" }]}>
                <span>{link.label}</span>
                {link.hint && <small>{link.hint}</small>}
              </a>
            ))}
          </div>

          <p class="admin-nav__label">Accès rapides</p>
          <div class="admin-nav__groups">
            {navGroups.map((group) => (
              <details class="admin-nav__group" open={isGroupActive(group) || group.title === "Pages et textes"}>
                <summary>{group.title}</summary>
                <div>
                  {group.links.map((link) => (
                    <a href={link.href} class:list={[{ "is-active": isActive(link.active) }]}>
                      <span>{link.label}</span>
                      {link.hint && <small>{link.hint}</small>}
                    </a>
                  ))}
                </div>
              </details>
            ))}
          </div>
        </nav>

        <a class="admin-side__foot" href="/" target="_blank" rel="noreferrer">Voir le site public</a>
      </aside>

      <main class="admin-main">
        <slot />
      </main>
    </div>

    <style is:global>
      :root {
        --a-ink: #081611;
        --a-muted: #40534a;
        --a-line: #becbc4;
        --a-line-strong: #94a69c;
        --a-paper: #edf2ef;
        --a-surface: #ffffff;
        --a-red: #ed1515;
        --a-red-dark: #ed1515;
        --a-green: #0f6842;
        --a-dark: #071912;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--a-paper);
        color: var(--a-ink);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
        font-size: 17px;
        line-height: 1.6;
      }
      a { color: inherit; text-decoration: none; }
      .admin { display: grid; grid-template-columns: 300px minmax(0, 1fr); min-height: 100vh; max-width: 100vw; overflow-x: hidden; }
      .admin-side {
        position: sticky; top: 0; align-self: start;
        display: flex; flex-direction: column; gap: 10px;
        width: 300px; max-width: 100vw; min-width: 0; height: 100vh; padding: 20px 16px;
        background: var(--a-dark); color: #f4fbf7;
        overflow-x: hidden;
      }
      .admin-brand { display: flex; align-items: center; gap: 10px; min-width: 0; padding: 6px 8px 12px; }
      .admin-brand span { display: grid; font-weight: 800; line-height: 1.1; }
      .admin-brand small { color: #c6d8d0; font-size: 0.78rem; font-weight: 700; }
      .admin-nav {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        align-content: start;
        gap: 10px;
        min-width: 0;
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
        overflow-y: auto;
        padding-right: 2px;
      }
      .admin-nav__main,
      .admin-nav__groups,
      .admin-nav__group div {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 4px;
        min-width: 0;
        max-width: 100%;
      }
      .admin-nav a {
        display: grid; grid-template-columns: minmax(0, 1fr); gap: 1px; min-width: 0; max-width: 100%;
        padding: 10px 12px; border-radius: 8px; color: #eef7f2; font-weight: 700; font-size: 0.98rem;
        overflow: hidden;
        overflow-wrap: anywhere;
      }
      .admin-nav a span,
      .admin-nav a small {
        min-width: 0;
        max-width: 100%;
        white-space: normal;
        overflow-wrap: anywhere;
      }
      .admin-nav a small { color: #bad0c6; font-size: 0.8rem; font-weight: 700; line-height: 1.28; }
      .admin-nav a:hover { background: rgba(255,255,255,0.13); color: #fff; }
      .admin-nav a:hover small,
      .admin-nav a.is-active small { color: rgba(255,255,255,0.9); }
      .admin-nav a.is-active { background: var(--a-red); color: #fff; }
      .admin-nav a.is-prominent {
        border: 1px solid rgba(255,255,255,0.26);
        background: rgba(255,255,255,0.1);
      }
      .admin-nav a.is-prominent.is-active { background: var(--a-red); }
      .admin-nav__label {
        margin: 8px 8px 0; color: #b4cbc1; font-size: 0.76rem; font-weight: 850;
        text-transform: uppercase; letter-spacing: 0.04em;
      }
      .admin-nav__group {
        min-width: 0;
        max-width: 100%;
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 10px;
        background: rgba(255,255,255,0.055);
        overflow: hidden;
      }
      .admin-nav__group summary {
        display: flex; align-items: center; justify-content: space-between;
        gap: 8px;
        min-width: 0;
        padding: 9px 11px; cursor: pointer; color: #edf5f1;
        font-size: 0.86rem; font-weight: 850; text-transform: uppercase; letter-spacing: 0.02em;
        overflow-wrap: anywhere;
      }
      .admin-nav__group summary::after { content: "+"; color: #d7e5df; font-size: 0.95rem; }
      .admin-nav__group[open] summary::after { content: "–"; }
      .admin-nav__group div { padding: 0 6px 8px; }
      .admin-nav__group a { padding: 8px 9px; }
      .admin-side__foot {
        margin-top: auto; padding: 11px 12px; border: 1px solid rgba(255,255,255,0.24);
        border-radius: 8px; color: #e4f0eb; font-size: 0.94rem; font-weight: 750;
        max-width: 100%;
        overflow-wrap: anywhere;
      }
      .admin-side__foot:hover { color: #fff; }
      .admin-main { padding: 30px clamp(18px, 4vw, 46px); min-width: 0; }

      .admin-head { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
      .admin-head h1 { margin: 0; font-size: 1.95rem; }
      .admin-head p { margin: 4px 0 0; color: var(--a-muted); }

      .btn {
        display: inline-flex; align-items: center; gap: 6px; cursor: pointer;
        padding: 11px 17px; border-radius: 8px; border: 1px solid transparent;
        font: inherit; font-weight: 760; font-size: 1rem;
      }
      .btn--primary { background: var(--a-red); color: #fff; }
      .btn--primary:hover { background: var(--a-red-dark); }
      .btn--ghost { background: var(--a-surface); border-color: var(--a-line-strong); color: var(--a-ink); }
      .btn--ghost:hover { border-color: #6d8176; background: #f7faf8; }
      .btn--danger { background: #fff; border-color: #ed1515; color: var(--a-red-dark); }
      .btn--danger:hover { background: #fff0f0; }
      .btn--small { padding: 7px 11px; font-size: 0.92rem; }

      .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 16px; }
      .stat-card {
        display: grid; gap: 6px; padding: 20px; border: 1px solid var(--a-line-strong);
        border-radius: 12px; background: var(--a-surface); box-shadow: 0 8px 22px rgba(16,32,26,0.05);
      }
      .stat-card:hover { border-color: #72867b; }
      .stat-card strong { font-size: 2rem; line-height: 1; color: var(--a-red-dark); }
      .stat-card span { font-weight: 700; }
      .stat-card small { color: var(--a-muted); }

      .panel { border: 1px solid var(--a-line-strong); border-radius: 12px; background: var(--a-surface); overflow: hidden; box-shadow: 0 10px 24px rgba(8,22,17,0.06); }
      .table-scroll { width: 100%; overflow-x: auto; }
      table.data { width: 100%; border-collapse: collapse; min-width: 620px; }
      table.data th, table.data td { padding: 13px 15px; text-align: left; border-bottom: 1px solid #cbd6cf; vertical-align: top; }
      table.data th { background: #dfe8e3; border-bottom: 2px solid var(--a-line-strong); font-size: 0.86rem; text-transform: uppercase; letter-spacing: 0.03em; color: #14251e; }
      table.data td { color: #172820; background: #fff; font-weight: 520; }
      table.data tbody tr:nth-child(even) td { background: #f3f7f4; }
      table.data tbody tr:hover td { background: #e8f1ec; }
      table.data tr:last-child td { border-bottom: 0; }
      table.data .row-actions { display: flex; gap: 6px; white-space: nowrap; }
      .muted { color: var(--a-muted); }
      .empty { padding: 40px; text-align: center; color: var(--a-muted); }

      .badge { display: inline-block; padding: 3px 9px; border-radius: 999px; background: #dcebe3; color: #084f31; font-size: 0.86rem; font-weight: 800; }

      dialog.editor {
        width: min(680px, calc(100vw - 32px)); padding: 0; border: none; border-radius: 14px;
        box-shadow: 0 30px 80px rgba(0,0,0,0.35);
      }
      dialog.editor::backdrop { background: rgba(10,20,16,0.5); }
      .editor__head { display: flex; align-items: center; justify-content: space-between; padding: 18px 22px; border-bottom: 1px solid var(--a-line-strong); }
      .editor__head h2 { margin: 0; font-size: 1.32rem; }
      .editor__body { display: grid; gap: 14px; padding: 22px; max-height: 66vh; overflow-y: auto; }
      .editor__foot { display: flex; justify-content: flex-end; gap: 10px; padding: 16px 22px; border-top: 1px solid var(--a-line-strong); background: #eef3f0; }
      .field { display: grid; gap: 5px; }
      .field label { font-weight: 760; font-size: 0.98rem; }
      .field input[type="text"], .field input[type="number"], .field textarea, .field select {
        width: 100%; padding: 10px 12px; border: 1px solid var(--a-line-strong); border-radius: 8px;
        font: inherit; background: #fff; color: var(--a-ink);
      }
      .field textarea { min-height: 84px; resize: vertical; }
      .field textarea.paragraphs { min-height: 200px; }
      .field textarea.code { font-family: ui-monospace, "Cascadia Code", Consolas, monospace; font-size: 0.85rem; }
      .field .help { color: var(--a-muted); font-size: 0.88rem; font-weight: 600; }
      .field--check { display: flex; align-items: center; gap: 8px; }
      .field--check input { width: 18px; height: 18px; }
      .form-error { margin: 0 22px; padding: 10px 12px; border-radius: 8px; background: #fff0f0; color: var(--a-red-dark); font-size: 0.86rem; font-weight: 600; }
      [hidden] { display: none !important; }
      .req { color: var(--a-red); }
      .linkbtn { border: none; background: none; padding: 0; cursor: pointer; color: var(--a-red-dark); font: inherit; font-size: 0.92rem; font-weight: 760; }
      .linkbtn:hover { text-decoration: underline; }

      .filefield__row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
      .filefield__url { margin-top: 8px; }
      .filefield__preview { margin-top: 8px; }
      .filefield__img { max-width: 160px; max-height: 120px; border: 1px solid var(--a-line-strong); border-radius: 8px; background: #fff; padding: 4px; }
      .filefield__preview a { color: var(--a-red-dark); font-weight: 600; word-break: break-all; }
      .files { display: grid; gap: 10px; margin-bottom: 8px; }
      .files__row { display: grid; grid-template-columns: minmax(0, 1fr) auto auto; gap: 8px; align-items: start; }
      .files__preview { grid-column: 1 / -1; }
      .files__preview a { color: var(--a-red-dark); font-weight: 600; word-break: break-all; }

      .lines { display: grid; gap: 8px; margin-bottom: 8px; }
      .lines__row { display: flex; gap: 8px; align-items: center; }
      .lines__row input { flex: 1; }

      .ref { border: 1px solid var(--a-line-strong); border-radius: 8px; overflow: hidden; }
      .ref__filter { width: 100%; border: none; border-bottom: 1px solid var(--a-line-strong); padding: 9px 11px; font: inherit; }
      .ref__filter:focus { outline: none; }
      .ref__list { max-height: 220px; overflow-y: auto; }
      .ref__item { display: flex; align-items: center; gap: 8px; padding: 8px 11px; border-bottom: 1px solid #d7e0da; cursor: pointer; }
      .ref__item:last-child { border-bottom: 0; }
      .ref__item:hover { background: #f6f9f6; }
      .ref__item input { width: 16px; height: 16px; }

      .rep { display: grid; gap: 12px; margin-bottom: 8px; }
      .rep__row { border: 1px solid var(--a-line-strong); border-radius: 10px; padding: 14px; background: #f4f8f5; display: grid; gap: 10px; }
      .rep__fields { display: grid; gap: 10px; }
      .rep__del { justify-self: start; }

      @media (max-width: 900px) {
        .admin { grid-template-columns: 1fr; }
        .admin-side { position: static; width: 100%; height: auto; }
        .admin-nav { max-height: none; }
      }
    </style>
  </body>
</html>
