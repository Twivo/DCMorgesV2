---
import { collections } from "../lib/collections";
import { siteInfo } from "../data/site";

interface Props {
  title: string;
  active?: string; // collection name or "dashboard" | "site" | "media"
}

const { title, active } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <title>{title} · Admin {siteInfo.shortName}</title>
  </head>
  <body>
    <div class="admin">
      <aside class="admin-side">
        <a class="admin-brand" href="/admin">
          <img src={siteInfo.logo} alt="" width="34" height="34" />
          <span>Admin<small>{siteInfo.shortName}</small></span>
        </a>
        <nav class="admin-nav">
          <a href="/admin" class:list={[{ "is-active": active === "dashboard" }]}>Tableau de bord</a>
          <a href="/admin/content" class:list={[{ "is-active": active === "content" }]}>Gestion du contenu</a>
          <p class="admin-nav__label">Contenus</p>
          {collections.map((collection) => (
            <a href={`/admin/${collection.name}`} class:list={[{ "is-active": active === collection.name }]}>
              {collection.label}
            </a>
          ))}
          <p class="admin-nav__label">Configuration</p>
          <a href="/admin/media" class:list={[{ "is-active": active === "media" }]}>Médiathèque</a>
          <a href="/admin/site" class:list={[{ "is-active": active === "site" }]}>Réglages du site</a>
        </nav>
        <a class="admin-side__foot" href="/" target="_blank" rel="noreferrer">↗ Voir le site public</a>
      </aside>

      <main class="admin-main">
        <slot />
      </main>
    </div>

    <style is:global>
      :root {
        --a-ink: #10201a;
        --a-muted: #5f6f68;
        --a-line: #e0e6e2;
        --a-paper: #f4f6f4;
        --a-surface: #ffffff;
        --a-red: #c9332f;
        --a-red-dark: #9f2421;
        --a-green: #17784f;
        --a-dark: #10201a;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--a-paper);
        color: var(--a-ink);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
        font-size: 15px;
        line-height: 1.55;
      }
      a { color: inherit; text-decoration: none; }
      .admin { display: grid; grid-template-columns: 250px minmax(0, 1fr); min-height: 100vh; }
      .admin-side {
        position: sticky; top: 0; align-self: start;
        display: flex; flex-direction: column; gap: 6px;
        height: 100vh; padding: 18px 14px;
        background: var(--a-dark); color: #dfe8e3;
      }
      .admin-brand { display: flex; align-items: center; gap: 10px; padding: 6px 8px 14px; }
      .admin-brand span { display: grid; font-weight: 800; line-height: 1.1; }
      .admin-brand small { color: #9fb2aa; font-size: 0.72rem; font-weight: 600; }
      .admin-nav { display: grid; gap: 2px; overflow-y: auto; }
      .admin-nav a {
        padding: 9px 12px; border-radius: 8px; color: #cdd9d3; font-weight: 600; font-size: 0.92rem;
      }
      .admin-nav a:hover { background: rgba(255,255,255,0.08); color: #fff; }
      .admin-nav a.is-active { background: var(--a-red); color: #fff; }
      .admin-nav__label {
        margin: 14px 8px 4px; color: #7f948c; font-size: 0.68rem; font-weight: 800;
        text-transform: uppercase; letter-spacing: 0.04em;
      }
      .admin-side__foot { margin-top: auto; padding: 10px 12px; color: #9fb2aa; font-size: 0.82rem; }
      .admin-side__foot:hover { color: #fff; }
      .admin-main { padding: 30px clamp(18px, 4vw, 46px); min-width: 0; }

      .admin-head { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
      .admin-head h1 { margin: 0; font-size: 1.7rem; }
      .admin-head p { margin: 4px 0 0; color: var(--a-muted); }

      .btn {
        display: inline-flex; align-items: center; gap: 6px; cursor: pointer;
        padding: 10px 16px; border-radius: 8px; border: 1px solid transparent;
        font: inherit; font-weight: 700; font-size: 0.9rem;
      }
      .btn--primary { background: var(--a-red); color: #fff; }
      .btn--primary:hover { background: var(--a-red-dark); }
      .btn--ghost { background: var(--a-surface); border-color: var(--a-line); color: var(--a-ink); }
      .btn--ghost:hover { border-color: #b9c4be; }
      .btn--danger { background: #fff; border-color: #e6b9b7; color: var(--a-red-dark); }
      .btn--danger:hover { background: #fbeeed; }
      .btn--small { padding: 6px 10px; font-size: 0.82rem; }

      .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 16px; }
      .stat-card {
        display: grid; gap: 6px; padding: 20px; border: 1px solid var(--a-line);
        border-radius: 12px; background: var(--a-surface); box-shadow: 0 8px 22px rgba(16,32,26,0.05);
      }
      .stat-card:hover { border-color: #c7d2cc; }
      .stat-card strong { font-size: 2rem; line-height: 1; color: var(--a-red-dark); }
      .stat-card span { font-weight: 700; }
      .stat-card small { color: var(--a-muted); }

      .panel { border: 1px solid var(--a-line); border-radius: 12px; background: var(--a-surface); overflow: hidden; }
      .table-scroll { width: 100%; overflow-x: auto; }
      table.data { width: 100%; border-collapse: collapse; min-width: 620px; }
      table.data th, table.data td { padding: 11px 14px; text-align: left; border-bottom: 1px solid var(--a-line); vertical-align: top; }
      table.data th { background: #f2f5f2; font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.03em; color: #3a4a44; }
      table.data td { color: #2b3a34; }
      table.data tr:last-child td { border-bottom: 0; }
      table.data .row-actions { display: flex; gap: 6px; white-space: nowrap; }
      .muted { color: var(--a-muted); }
      .empty { padding: 40px; text-align: center; color: var(--a-muted); }

      .badge { display: inline-block; padding: 2px 8px; border-radius: 999px; background: #eef4f0; color: var(--a-green); font-size: 0.76rem; font-weight: 700; }

      /* Dialog / form */
      dialog.editor {
        width: min(680px, calc(100vw - 32px)); padding: 0; border: none; border-radius: 14px;
        box-shadow: 0 30px 80px rgba(0,0,0,0.35);
      }
      dialog.editor::backdrop { background: rgba(10,20,16,0.5); }
      .editor__head { display: flex; align-items: center; justify-content: space-between; padding: 18px 22px; border-bottom: 1px solid var(--a-line); }
      .editor__head h2 { margin: 0; font-size: 1.15rem; }
      .editor__body { display: grid; gap: 14px; padding: 22px; max-height: 66vh; overflow-y: auto; }
      .editor__foot { display: flex; justify-content: flex-end; gap: 10px; padding: 16px 22px; border-top: 1px solid var(--a-line); background: #fafbfa; }
      .field { display: grid; gap: 5px; }
      .field label { font-weight: 700; font-size: 0.85rem; }
      .field input[type="text"], .field input[type="number"], .field textarea, .field select {
        width: 100%; padding: 9px 11px; border: 1px solid var(--a-line); border-radius: 8px;
        font: inherit; background: #fff; color: var(--a-ink);
      }
      .field textarea { min-height: 84px; resize: vertical; }
      .field textarea.paragraphs { min-height: 200px; }
      .field textarea.code { font-family: ui-monospace, "Cascadia Code", Consolas, monospace; font-size: 0.85rem; }
      .field .help { color: var(--a-muted); font-size: 0.78rem; }
      .field--check { display: flex; align-items: center; gap: 8px; }
      .field--check input { width: 18px; height: 18px; }
      .form-error { margin: 0 22px; padding: 10px 12px; border-radius: 8px; background: #fbeeed; color: var(--a-red-dark); font-size: 0.86rem; font-weight: 600; }
      [hidden] { display: none !important; }
      .req { color: var(--a-red); }
      .linkbtn { border: none; background: none; padding: 0; cursor: pointer; color: var(--a-red-dark); font: inherit; font-size: 0.82rem; font-weight: 700; }
      .linkbtn:hover { text-decoration: underline; }

      /* File upload */
      .filefield__row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
      .filefield__url { margin-top: 8px; }
      .filefield__preview { margin-top: 8px; }
      .filefield__img { max-width: 160px; max-height: 120px; border: 1px solid var(--a-line); border-radius: 8px; background: #fff; padding: 4px; }
      .filefield__preview a { color: var(--a-red-dark); font-weight: 600; word-break: break-all; }
      .files { display: grid; gap: 10px; margin-bottom: 8px; }
      .files__row { display: grid; grid-template-columns: minmax(0, 1fr) auto auto; gap: 8px; align-items: start; }
      .files__preview { grid-column: 1 / -1; }
      .files__preview a { color: var(--a-red-dark); font-weight: 600; word-break: break-all; }

      /* Add/remove lines */
      .lines { display: grid; gap: 8px; margin-bottom: 8px; }
      .lines__row { display: flex; gap: 8px; align-items: center; }
      .lines__row input { flex: 1; }

      /* Reference picker */
      .ref { border: 1px solid var(--a-line); border-radius: 8px; overflow: hidden; }
      .ref__filter { width: 100%; border: none; border-bottom: 1px solid var(--a-line); padding: 9px 11px; font: inherit; }
      .ref__filter:focus { outline: none; }
      .ref__list { max-height: 220px; overflow-y: auto; }
      .ref__item { display: flex; align-items: center; gap: 8px; padding: 7px 11px; border-bottom: 1px solid #eef2ef; cursor: pointer; }
      .ref__item:last-child { border-bottom: 0; }
      .ref__item:hover { background: #f6f9f6; }
      .ref__item input { width: 16px; height: 16px; }

      /* Repeater */
      .rep { display: grid; gap: 12px; margin-bottom: 8px; }
      .rep__row { border: 1px solid var(--a-line); border-radius: 10px; padding: 14px; background: #fafbfa; display: grid; gap: 10px; }
      .rep__fields { display: grid; gap: 10px; }
      .rep__del { justify-self: start; }

      @media (max-width: 820px) {
        .admin { grid-template-columns: 1fr; }
        .admin-side { position: static; height: auto; flex-direction: column; }
        .admin-nav { grid-auto-flow: row; }
      }
    </style>
  </body>
</html>
